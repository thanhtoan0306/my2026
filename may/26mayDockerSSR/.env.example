# Tên image trên Docker Hub (hiển thị trên UI + dùng khi tag/push)
DOCKER_IMAGE=your-dockerhub-user/docker-ssr-hello:latest

# Đường dẫn thư mục project (hiển thị trong lệnh trên UI)
PROJECT_DIR=may/26mayDockerSSR

PORT=8080

# Offline bundle (export/load)
OFFLINE_IMAGE=docker-ssr-hello:offline
OFFLINE_TAR=output/docker-ssr-hello.tar
