rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    match /artifacts/{appId}/public/data/notes/{noteId} {
      allow read, write: if request.auth != null;
    }
    match /artifacts/{appId}/public/data/todos/{todoId} {
      allow read, write: if request.auth != null;
    }
    match /apps/{projectName} {
      allow read: if request.auth != null;
      allow write: if false;
    }
    match /apps/{projectName}/todos/{todoId} {
      allow read, write: if request.auth != null;
    }
    match /apps/{projectName}/notes/{noteId} {
      allow read, write: if request.auth != null;
    }
    match /apps/{projectName}/{collection}/{docId} {
      allow read, write: if request.auth != null;
    }
  }
}
