rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    match /artifacts/{appId}/public/data/notes/{noteId} {
      allow read, write: if request.auth != null;
    }
    match /artifacts/{appId}/public/data/todos/{todoId} {
      allow read, write: if request.auth != null;
    }
  }
}
