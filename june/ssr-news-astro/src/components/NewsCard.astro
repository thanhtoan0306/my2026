---
import type { Article } from '../types/news';
import { formatPublishedAt } from '../lib/news';

interface Props {
	article: Article;
}

const { article } = Astro.props;
---

<article class="card">
	<div class="meta">
		<span class="badge">{article.category}</span>
		<time class="muted" datetime={article.publishedAt}>{formatPublishedAt(article.publishedAt)}</time>
	</div>
	<h2>
		<a href={`/news/${article.slug}`}>{article.title}</a>
	</h2>
	<p class="summary">{article.summary}</p>
	<div class="footer">
		<span class="muted">By {article.author}</span>
		<a class="read-more" href={`/news/${article.slug}`}>Read article →</a>
	</div>
</article>

<style>
	.card {
		padding: 1.5rem;
		border: 1px solid var(--border);
		border-radius: var(--radius);
		background: var(--surface);
		transition: background 0.15s ease, border-color 0.15s ease;
	}

	.card:hover {
		background: var(--surface-hover);
		border-color: color-mix(in srgb, var(--accent) 35%, var(--border));
	}

	.meta {
		display: flex;
		flex-wrap: wrap;
		align-items: center;
		gap: 0.75rem;
		margin-bottom: 0.75rem;
	}

	h2 {
		margin: 0 0 0.75rem;
		font-size: 1.35rem;
		line-height: 1.3;
	}

	h2 a {
		color: var(--text);
		text-decoration: none;
	}

	h2 a:hover {
		color: var(--accent);
	}

	.summary {
		margin: 0 0 1rem;
		color: var(--muted);
	}

	.footer {
		display: flex;
		flex-wrap: wrap;
		justify-content: space-between;
		align-items: center;
		gap: 0.75rem;
		font-size: 0.875rem;
	}

	.read-more {
		font-weight: 600;
	}
</style>
