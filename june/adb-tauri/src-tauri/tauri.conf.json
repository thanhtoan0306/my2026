{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "ADB Tauri",
  "version": "1.0.0",
  "identifier": "com.my2026.adb-tauri",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:5173",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "ADB Tauri",
        "width": 1100,
        "height": 780,
        "minWidth": 900,
        "minHeight": 600
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "externalBin": ["binaries/adb-sidecar"]
  }
}
